// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  lead
  client
  inactive
}

enum IndicationStatus {
  pending
  approved
  rejected
}

enum TransactionType {
  indication_reward
  offer_redemption
  withdrawal
  manual_adjustment
}

enum GenerationUnitType {
  real_time
  day
  month
  year
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String
  password             String
  roles                String[]  @default(["user"])
  permissions          String[]  @default(["read_inverters", "create_inverter", "read_generation_data", "create_generation_unit"])
  clientId             String?
  isActive             Boolean   @default(true)
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  payerUnits ConsumerUnit[] @relation("PayerUnits")

  @@index([email])
  @@index([clientId])
  @@index([email, isActive])
  @@map("user")
}

model Client {
  id              String  @id @default(dbgenerated("(concat('client_', gen_random_uuid()))::TEXT"))
  name            String
  email           String  @unique
  cpfCnpj         String  @unique
  phone           String?
  address         String?
  avgEnergyCost   Float?
  enelInvoiceFile String?

  soloCoinBalance Float        @default(0)
  indicationCode  String       @unique
  status          ClientStatus @default(lead)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users                 User[]
  consumptions          Consumption[]
  indicationsAsReferrer Indication[]      @relation("Referrer")
  indicationsAsReferred Indication[]      @relation("Referred")
  transactions          Transaction[]
  offerRedemptions      OfferRedemption[]
  energyBills           EnergyBill[]

  // Energy
  plants            Plant[]
  inverters         Inverter[]
  consumerUnits     ConsumerUnit[]
  creditAllocations CreditAllocation[]
  investments       Investment[]

  @@index([email])
  @@index([cpfCnpj])
  @@map("client")
}

model Plant {
  id String @id @default(dbgenerated("(concat('plant_', gen_random_uuid()))::TEXT"))

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  name             String?
  provider         String?
  providerStatus   String?
  providerPlantId  String?
  installedPowerKw Decimal? @db.Decimal(10, 3)
  totalEnergyKwh   Decimal? @db.Decimal(14, 4)
  address          String?
  city             String?
  state            String?
  timezone         String?
  latitude         Decimal? @db.Decimal(10, 7)
  longitude        Decimal? @db.Decimal(10, 7)
  providerMetadata Json?

  inverters         Inverter[]
  consumerUnits     ConsumerUnit[]
  creditAllocations CreditAllocation[]
  energyBills       EnergyBill[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([clientId])
  @@index([providerPlantId])
  @@map("plant")
}

model Inverter {
  id String @id @default(dbgenerated("(concat('inverter_', gen_random_uuid()))::TEXT"))

  name              String?
  provider          String
  providerId        String
  providerApiKey    String?
  providerApiSecret String?
  providerUrl       String?
  providerPlantId   String?
  providerPlantName String?
  providerStatus    String?
  providerConfig    Json?
  providerMetadata  Json?

  serialNumber    String?
  manufacturer    String?
  modelName       String?
  firmwareVersion String?
  nominalPowerKw  Decimal? @db.Decimal(10, 3)
  timezone        String?

  syncEnabled          Boolean   @default(true)
  syncIntervalMinutes  Int?
  lastSyncAt           DateTime?
  lastSuccessfulSyncAt DateTime?
  lastSyncStatus       String?
  lastSyncError        String?
  installedAt          DateTime?
  commissionedAt       DateTime?

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  plant   Plant?  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  plantId String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  generationUnits GenerationUnit[]

  @@index([clientId])
  @@index([plantId])
  @@index([providerId])
  @@index([provider, providerId])
  @@index([providerPlantId])
  @@index([syncEnabled])
  @@index([lastSyncStatus])
  @@map("inverter")
}

model ConsumerUnit {
  id String @id @default(dbgenerated("(concat('consumer_unit_', gen_random_uuid()))::TEXT"))

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  name        String?
  isGenerator Boolean @default(true)
  isConsumer  Boolean @default(true)

  accountHolder      String?
  accountNumber      String?
  clientNumber       String?
  installationNumber String?
  distributor        String?
  address            String?
  city               String?
  state              String?
  status             String?

  // Payer (scoped login who pays this UC)
  payerName  String?
  payerEmail String?
  payerPhone String?
  payerUser   User?   @relation("PayerUnits", fields: [payerUserId], references: [id])
  payerUserId String?

  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  plantId String

  energyBills EnergyBill[]

  allocationsFrom CreditAllocation[] @relation("CreditAllocationFrom")
  allocationsTo   CreditAllocation[] @relation("CreditAllocationTo")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([clientId])
  @@index([plantId])
  @@index([clientId, plantId])
  @@index([clientId, clientNumber])
  @@index([payerUserId])
  @@map("consumer_unit")
}

model CreditAllocation {
  id String @id @default(dbgenerated("(concat('credit_allocation_', gen_random_uuid()))::TEXT"))

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  plantId String

  from   ConsumerUnit @relation("CreditAllocationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  fromId String

  to   ConsumerUnit @relation("CreditAllocationTo", fields: [toId], references: [id], onDelete: Cascade)
  toId String

  allocationPercentage Decimal   @db.Decimal(5, 2)
  startsAt             DateTime?
  endsAt               DateTime?
  isActive             Boolean   @default(true)

  enelSyncStatus   String    @default("draft")
  requestedAt      DateTime?
  appliedAt        DateTime?
  effectiveDate    DateTime? @db.Date
  enelProtocol     String?
  syncError        String?
  requestedByUserId String?
  appliedByUserId  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([clientId])
  @@index([plantId])
  @@index([fromId])
  @@index([toId])
  @@index([clientId, plantId])
  @@index([clientId, isActive])
  @@index([fromId, toId])
  @@index([enelSyncStatus])
  @@map("credit_allocation")
}

model GenerationUnit {
  id String @id @default(dbgenerated("(concat('generation_unit_', gen_random_uuid()))::TEXT"))

  power  Float
  energy Float

  generationUnitType GenerationUnitType @default(real_time)
  source             String?
  providerRecordId   String?
  rawPayload         Json?

  timestamp DateTime @default(now())

  inverter   Inverter @relation(fields: [inverterId], references: [id], onDelete: Cascade)
  inverterId String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([inverterId, generationUnitType, providerRecordId])
  @@index([inverterId])
  @@index([inverterId, generationUnitType])
  @@index([inverterId, generationUnitType, timestamp])
  @@index([providerRecordId])
  @@map("generation_unit")
}

model Indication {
  id String @id @default(dbgenerated("(concat('indication_', gen_random_uuid()))::TEXT"))

  referrer   Client @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId String

  referred   Client @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  referredId String

  status IndicationStatus @default(pending)

  jestorId     String? @unique
  projectValue Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerId])
  @@index([referredId])
  @@map("indication")
}

model Offer {
  id String @id @default(dbgenerated("(concat('offer_', gen_random_uuid()))::TEXT"))

  title       String
  description String
  partner     String
  cost        Float

  discount                String?
  imageUrl                String?
  confirmationCode        String? // Código secreto para parceiro confirmar uso
  maxRedemptionsPerClient Int     @default(1) // Máximo de vezes que cada cliente pode resgatar

  validFrom DateTime?
  validTo   DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions OfferRedemption[]

  @@map("offer")
}

enum RedemptionStatus {
  pending
  used
  expired
}

enum BillPaymentStatus {
  a_pagar
  paga
  vencida
}

model OfferRedemption {
  id String @id @default(dbgenerated("(concat('redemption_', gen_random_uuid()))::TEXT"))

  redemptionCode String @unique // Código único de 6 caracteres para validação pelo parceiro

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  status RedemptionStatus @default(pending)

  redeemedAt DateTime  @default(now())
  usedAt     DateTime?
  expiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([offerId])
  @@index([clientId, status])
  @@index([redemptionCode])
  @@map("offer_redemption")
}

model FAQ {
  id String @id @default(dbgenerated("(concat('faq_', gen_random_uuid()))::TEXT"))

  question String
  answer   String
  category String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq")
}

model Transaction {
  id String @id @default(dbgenerated("(concat('transaction_', gen_random_uuid()))::TEXT"))

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  type        TransactionType
  amount      Float // positive for credits, negative for debits
  description String?

  offerId      String? // for offer redemptions
  indicationId String? // for indication rewards

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([clientId, type])
  @@map("transaction")
}

model Consumption {
  id String @id @default(dbgenerated("(concat('consumption_', gen_random_uuid()))::TEXT"))

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  competenceDate DateTime // The month/year this consumption refers to (e.g., 2023-10-01)

  consumptionKwh    Float // Consumo de energia da rede (kWh)
  injectedEnergyKwh Float // Energia injetada (kWh)
  tariffPerKwh      Float // Tarifa da concessionária (R$/kWh)
  totalBillValue    Float // Valor final da fatura (R$)

  // Optional breakdown or calculated fields if needed later
  // For now, storing the core values for savings calculation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, competenceDate]) // One consumption record per client per month
  @@index([clientId])
  @@map("consumption")
}

model EnergyBill {
  id String @id @default(dbgenerated("(concat('energy_bill_', gen_random_uuid()))::TEXT"))

  billFileUrl     String?
  rawBillFileKey  String? // Key in the S3 bucket where the raw bill file is stored
  rawBillFileSize Int? // Size of the raw bill file in bytes

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  plantId String

  consumerUnit   ConsumerUnit @relation(fields: [consumerUnitId], references: [id], onDelete: Cascade)
  consumerUnitId String

  competenceDate DateTime // The month/year this consumption refers to (e.g., 2023-10-01)
  referenceMonth Int
  referenceYear  Int

  // Customer data
  accountHolder     String?
  accountNumber     String?
  clientNumber      String?
  instalationNumber String?
  distributor       String?
  consumerClass     String?
  tariffModality    String?
  connectionType    String?
  tariffPeriod      String?
  billingDays       Int?
  readingPeriodFrom DateTime? @db.Date
  readingPeriodTo   DateTime? @db.Date
  creditExpiryDate  DateTime? @db.Date

  // Energy data
  monitoredGenerationKwh Decimal? @db.Decimal(14, 4)
  billedConsumptionKwh   Decimal? @db.Decimal(14, 4)
  consumptionKwh         Decimal? @db.Decimal(14, 4) // Consumo de energia da rede (kWh)
  realConsumptionKwh     Decimal? @db.Decimal(14, 4)
  injectedEnergyKwh      Decimal? @db.Decimal(14, 4) // Energia injetada (kWh)
  compensatedEnergyKwh   Decimal? @db.Decimal(14, 4)
  previousCreditsKwh     Decimal? @db.Decimal(14, 4)
  currentCreditsKwh      Decimal? @db.Decimal(14, 4)
  expectedGenerationKwh  Decimal? @db.Decimal(14, 4)
  generationEfficiency   Decimal? @db.Decimal(8, 4)
  meterReadingCurrent    Decimal? @db.Decimal(14, 4)
  meterReadingPrevious   Decimal? @db.Decimal(14, 4)
  demandContractedKw     Decimal? @db.Decimal(14, 4)
  demandMeasuredKw       Decimal? @db.Decimal(14, 4)

  // Financial data
  totalBillValue     Decimal? @db.Decimal(14, 2) // Valor final da fatura (R$)
  totalAmount        Decimal? @db.Decimal(14, 2)
  energyCost         Decimal? @db.Decimal(14, 2)
  availabilityCost   Decimal? @db.Decimal(14, 2)
  publicLightingCost Decimal? @db.Decimal(14, 2)
  icmsCost           Decimal? @db.Decimal(14, 2)
  pisCost            Decimal? @db.Decimal(14, 2)
  cofinsCost         Decimal? @db.Decimal(14, 2)
  pisCofinsCost      Decimal? @db.Decimal(14, 2)
  tariffPerKwh       Decimal? @db.Decimal(12, 6) // Tarifa da concessionária (R$/kWh)
  tariffTeValue      Decimal? @db.Decimal(12, 6)
  tariffTusdValue    Decimal? @db.Decimal(12, 6)
  tariffFlag         String?
  tariffFlagCost     Decimal? @db.Decimal(14, 2)
  sectoralCharges    Decimal? @db.Decimal(14, 2)
  fineAmount         Decimal? @db.Decimal(14, 2)
  interestAmount     Decimal? @db.Decimal(14, 2)
  otherCharges       Decimal? @db.Decimal(14, 2)
  estimatedSavings   Decimal? @db.Decimal(14, 2)

  // AI analysis and extracted details
  aiAnalysis        String?
  aiExplanations    Json?
  aiRecommendations Json?
  alerts            Json?
  extraCharges      Json?
  billingItems      Json?
  creditSummary     Json?
  billScore         Decimal? @db.Decimal(5, 2)
  status            String?

  // Payment / Contas a pagar
  paymentStatus BillPaymentStatus @default(a_pagar)
  dueDate       DateTime?         @db.Date
  paidAt        DateTime?
  amountDue     Decimal?          @db.Decimal(14, 2)
  pixCode       String?
  barcode       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([consumerUnitId, referenceMonth, referenceYear])
  @@index([clientId])
  @@index([plantId])
  @@index([consumerUnitId])
  @@index([referenceYear, referenceMonth])
  @@index([clientId, referenceYear, referenceMonth])
  @@index([status])
  @@index([clientId, paymentStatus])
  @@map("energy_bill")
}

model Investment {
  id String @id @default(dbgenerated("(concat('investment_', gen_random_uuid()))::TEXT"))

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  totalInvested   Decimal   @db.Decimal(14, 2)
  startDate       DateTime  @db.Date
  expectedPayoff  DateTime? @db.Date
  monthlyReturn   Decimal?  @db.Decimal(14, 2) // optional override; else derived from bills savings

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([clientId])
  @@map("investment")
}
